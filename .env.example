# ============================================================
# Beaverworld Project Management — Environment Variables
#
# Copy this file to `.env.local` and fill in real values.
# `.env*` files are gitignored — never commit your real secrets.
# Anything prefixed with NEXT_PUBLIC_ is bundled into the browser
# and is publicly visible; keep secrets WITHOUT that prefix.
# ============================================================

# ---- Supabase ----
# Project URL and public anon key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key — SERVER ONLY. Bypasses Row Level Security.
# Never expose this to the client or prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App ----
# Public base URL of the deployment, used to build links in notifications/emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Default password used when provisioning new team accounts.
NEXT_PUBLIC_DEFAULT_USER_PASSWORD=change-me

# ---- Discord notifications ----
# Incoming webhook URL for the team's Discord channel.
# Keep this SERVER-ONLY (no NEXT_PUBLIC_ prefix) so it is not shipped to the browser.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/yyyyy

# ---- Plastic SCM (UVCS) webhook ----
# Shared secret Plastic SCM must send as `?token=` when calling /api/uvcs-webhook.
UVCS_WEBHOOK_TOKEN=your-webhook-token

# ---- Email (Resend) ----
RESEND_API_KEY=re_your_resend_key
EMAIL_FROM="BeaverWorld Dev <notifications@example.com>"

# ---- Sentry (error monitoring) ----
# DSN for the browser/edge runtimes (public).
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx.ingest.sentry.io/xxxxx
# DSN for the server runtime.
SENTRY_DSN=https://xxxxx.ingest.sentry.io/xxxxx
# Auth token for uploading source maps at build time (CI/build only).
SENTRY_AUTH_TOKEN=sntryu_your_token

# ---- Ops ----
# Kill switch: set to "true"/"1"/"yes" to serve 503 on the app surface
# (keeps /api routes alive so webhooks keep working).
ARGUS_DEMO_DOWN=false
